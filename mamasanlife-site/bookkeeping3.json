      "_type": "block",
      "children": [
        {
          "_key": "b1e2b4c52d36",
          "_type": "span",
          "marks": [],
          "text": "【自信回復】"
        },
        {
          "_key": "276ba20a84d8",
          "_type": "span",
          "marks": [],
          "text": "「やればできる！」という実感が得られます"
        }
      ],
      "listItem": "number",
