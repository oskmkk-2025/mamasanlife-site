      "_type": "block",
      "children": [
        {
          "_key": "0290fd7c11e6",
          "_type": "span",
          "marks": [],
          "text": "【スキルアップ】"
        },
        {
          "_key": "e2d10a06b740",
          "_type": "span",
          "marks": [],
          "text": "どんな業界でも役立つ、普遍的な知識が身につきます"
        }
      ],
      "listItem": "number",
      "markDefs": [],
      "style": "normal"
    },
    {
