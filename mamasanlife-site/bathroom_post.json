      ],
      "markDefs": [],
      "style": "normal"
    },
    {
      "_key": "44c79ad488bd",
      "_type": "block",
      "children": [
        {
          "_key": "6e9895d7328a",
          "_type": "span",
          "marks": [],
          "text": " 【プライバシー保護】 　"
        }
      ],
      "markDefs": [],
      "style": "normal"
    },
    {
      "_key": "10ad17e47450",
      "_type": "block",
      "children": [
        {
          "_key": "8085e6666add",
          "_type": "span",
          "marks": [],
          "text": "予約が確定するまで各店に個人情報が公開されないので安心して問い合わせることができます。 "
