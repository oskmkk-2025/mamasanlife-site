          "_key": "39a4fc14367b",
          "_type": "span",
          "marks": [],
          "text": "お風呂の掃除って、忙しい主婦の皆さんにとって体力もいるし時間もかかって大変なんですよね。"
        }
      ],
      "markDefs": [],
