      "_type": "block",
      "children": [
        {
          "_key": "3b5ea7423c87",
          "_type": "span",
          "marks": [],
          "text": "ここで比較している会社の紹介"
        }
      ],
      "markDefs": [],
      "style": "h2"
    },
    {
      "_key": "2b9bc56e1444",
      "_type": "block",
