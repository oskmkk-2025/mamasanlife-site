{
  "redirects": [
    { "source": "/:year(\\d{4})/:month(\\d{2})/:slug/", "destination": "/:slug", "permanent": true },
    { "source": "/:year(\\d{4})/:month(\\d{2})/:slug",  "destination": "/:slug", "permanent": true },
    { "source": "/page/:page(\\d+)/", "destination": "/", "permanent": true },
    { "source": "/page/:page(\\d+)",  "destination": "/", "permanent": true },
    { "source": "/category/:slug/page/:page(\\d+)", "destination": "/:slug", "permanent": true },
    { "source": "/category/:slug/", "destination": "/:slug", "permanent": true },
    { "source": "/category/:slug",  "destination": "/:slug", "permanent": true },
    { "source": "/tag/:slug/:rest*", "destination": "/search?tag=:slug", "permanent": true },
    { "source": "/tag/:slug",        "destination": "/search?tag=:slug", "permanent": true },
    { "source": "/(.*)/amp/",  "destination": "/$1", "permanent": true },
    { "source": "/(.*)/amp",   "destination": "/$1", "permanent": true },
    { "source": "/index.php/(.*)", "destination": "/$1", "permanent": true },
    { "source": "/feed",       "destination": "/rss.xml", "permanent": true },
    { "source": "/feed/",      "destination": "/rss.xml", "permanent": true },
    { "source": "/wp-login.php", "destination": "/", "permanent": true },
    { "source": "/wp-admin/:path*", "destination": "/", "permanent": true },
    { "source": "/wp-content/:path*", "destination": "/", "permanent": true },
    { "source": "/feature/referral", "destination": "/feature", "permanent": true },
    {
      "source": "/(.*)",
      "destination": "https://mamasanmoney-bu.com/$1",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.mamasanmoney-bu.com" }]
    }
  ],
  "crons": [
    { "path": "/api/cron/line/daily-broadcast", "schedule": "0 11 * * *" }
  ]
}
